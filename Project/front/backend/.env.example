# SOLO Quiz Generator Backend - Configuration

# Ollama (local LLM) - used by content_parser, quiz_generator,
# translation_service and chatbot_service.
OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_MODEL=qwen2.5:14b-instruct-q4_K_M

# API Configuration
OPENROUTER_API_KEY = ""  # Add your API key here
OPENROUTER_API_KEY_2 = ""
OPENROUTER_API_KEY_3 = ""
OPENROUTER_API_KEY_4 = ""
OPENROUTER_API_KEY_5 = ""

# Flask Configuration
FLASK_ENV = "development"
DEBUG = True
HOST = "localhost"
PORT = 5000

# CORS Configuration
ALLOWED_ORIGINS = ["http://localhost:3000", "http://localhost:5000"]

# File Upload Configuration
MAX_FILE_SIZE = 30 * 1024 * 1024  # 10MB
ALLOWED_EXTENSIONS = {'txt'}

# Quiz Generation Configuration
MAX_CHAPTERS = 10
QUESTIONS_PER_CHAPTER = 4
SOLO_LEVELS = ['prestructural', 'multistructural', 'relational', 'extended_abstract']
